name: Airflow Pipeline CI

on:
push:
branches:
- master

jobs:
build:
runs-on: ubuntu-latest

```
steps:
  - name: Checkout Code
    uses: actions/checkout@v4

  - name: Setup Python
    uses: actions/setup-python@v5
    with:
      python-version: "3.12"

  - name: Install Dependencies
    run: |
      pip install pandas

  - name: Validate Python Files
    run: |
      python -m py_compile scripts/*.py
```